{
  "name": "@zients/minimax-sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for MiniMax multimodal APIs",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "format:check": "prettier --check src/ tests/",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "zients",
    "minimax",
    "ai",
    "sdk",
    "llm",
    "tts",
    "text-generation",
    "video-generation",
    "image-generation"
  ],
  "author": "Zients",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zients/minimax-sdk",
    "directory": "typescript"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
